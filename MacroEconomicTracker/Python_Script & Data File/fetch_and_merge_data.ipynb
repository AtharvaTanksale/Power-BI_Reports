   "source": [
    "import pandas as pd \n",
    "import yfinance as yf\n",
    "import pandas_datareader.data as web\n",
    "import datetime\n",
    "import os"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 8,
   "id": "cb584324-a44c-4eed-a557-c34392cb085e",
   "metadata": {},
   "outputs": [],
   "source": [
    "\n",
    "def fetch_and_merge_data():\n",
    "    #step 1: verifying the timeline for the data pull\n",
    "    start_date =datetime.datetime(2015,1,1)\n",
    "    end_date= datetime.datetime.today()\n",
    "    #step 2: filepath for the fallback csv\n",
    "    fallback_file_path= \"macro_tracker_data.csv\"\n",
    "    try:\n",
    "        print(\"Fetching Market data...\")\n",
    "        sp500 = yf.download('^GSPC',start=start_date, end =end_date)\n",
    "        if 'Adj Close' in sp500 in sp500.columns:\n",
    "            sp500 = sp500[['Adj Close']]\n",
    "        else:\n",
    "            sp500 = sp500[['Close']]\n",
    "        sp500.columns = ['SP500_Price']\n",
    "        sp500.index = sp500.index.tz_localize(None)\n",
    "\n",
    "        print (\"Fetching macro data...\")\n",
    "        fed_funds = web.DataReader('FEDFUNDS', 'fred', start_date, end_date)\n",
    "        fed_funds = fed_funds.rename(columns={'FEDFUNDS':'Interest_Rate'})\n",
    "\n",
    "        print(\"Merging datasets..\")\n",
    "        merged_data = pd.merge_asof(\n",
    "            sp500.sort_index(),\n",
    "            fed_funds.sort_index(),\n",
    "            left_index = True,\n",
    "            right_index = True,\n",
    "            direction = 'backward'\n",
    "        )\n",
    "\n",
    "        merged_data.dropna(inplace=True)\n",
    "        \n",
    "       
    "        merged_data.index.name = 'Date'\n",
    "        merged_data.reset_index(inplace=True)\n",
    "        \n",
    "        
    "        merged_data.to_csv(fallback_file_path, index=False)\n",
    "        print(f\"success! Data saved to {fallback_file_path}\")\n",
    "\n",
    "        return merged_data\n",
    "\n",
    "    except Exception as e:\n",
    "        print(f\"API Extraction Failed: {e}\")\n",
    "        print(\"Attempting to load data from local fallback CSV...\")\n",
    "        try:\n",
    "            backup_data = pd.read_csv(fallback_file_path)\n",
    "            print(\"Successfully loaded fallback data.\")\n",
    "            return backup_data\n",
    "        except FileNotFoundError:\n",
    "            print(f\"Critical Error: Fallback file not found at {fallback_file_path}.\")\n",
    "            return None"
   ]
  },
